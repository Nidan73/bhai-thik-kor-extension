{
  "manifest_version": 3,
  "name": "Bhai Thik Kor",
  "description": "Turn rough ideas into expert AI prompts - wherever you write.",
  "version": "0.1.0",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Bhai Thik Kor",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "MacCtrl+B"
      },
      "description": "Open Bhai Thik Kor"
    },
    "improve-selection": {
      "suggested_key": {
        "default": "Alt+I",
        "mac": "MacCtrl+I"
      },
      "description": "Improve selected text or active input"
    }
  },
  "host_permissions": [
    "https://bhaithikkor.vercel.app/*"
  ],
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
